{
  "name": "codemirror-lang-hledger",
  "version": "0.1.1",
  "description": "hledger journal format language support for CodeMirror",
  "scripts": {
    "test": "mocha test/test.js",
    "prepare": "rollup -c",
    "demo": "npm run prepare && vite demo"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "keywords": [
    "codemirror",
    "hledger",
    "journal",
    "accounting",
    "plaintext-accounting",
    "syntax-highlighting"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KonradStanski/codemirror-hledger.git"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.8"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.1.0",
    "codemirror": "^6.0.2",
    "mocha": "^11.7.1",
    "rollup": "^4.45.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.21"
  },
  "license": "MIT"
}
